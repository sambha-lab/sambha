{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local", "**/.env.local", "**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**",
        "target/**"
      ]
    },
    "build:contracts": {
      "dependsOn": ["^build:contracts"],
      "inputs": ["contracts/**/*.rs", "contracts/**/Cargo.toml", "contracts/Cargo.lock"],
      "outputs": ["target/**", "contracts/target/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "contracts/**/*.rs", "contracts/**/Cargo.toml", "tests/**"],
      "outputs": ["coverage/**"]
    },
    "test:contracts": {
      "dependsOn": ["build:contracts"],
      "inputs": ["contracts/**/*.rs", "contracts/**/Cargo.toml", "contracts/Cargo.lock"],
      "outputs": ["target/**", "contracts/target/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": ["$TURBO_DEFAULT$", "contracts/**/*.rs"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "inputs": ["$TURBO_DEFAULT$", "contracts/**/*.rs"]
    },
    "format": {
      "inputs": ["$TURBO_DEFAULT$", "contracts/**/*.rs"]
    },
    "clean": {
      "cache": false
    },
    "deploy": {
      "dependsOn": ["build", "test"],
      "cache": false
    },
    "deploy:contracts": {
      "dependsOn": ["build:contracts", "test:contracts"],
      "cache": false
    }
  }
}
